class C {
  int x;
  final int y = 10;
  boolean b1 = false;
  boolean b2 = false;
  int ta[y];
  boolean tb[y];

  int  somme( int max) {
  	int t = 5;

	while ( max > 0) {
		t += max;
		max = max - 1;
	};
	return t;
   };

   boolean test(int a, int b) {
	return a > b;
   };

   void f(){
   	x = y * x;
	x = x / x;
	x++;
   };

   main {
 	if (test(y,9) && (b1 || (!b2))) {
		x = somme(2); // x = 8
	} else {
		x++;
	};
	if (x == 8) {
	    tb[0] = b1 && (!b1); // tb[0] = false
		ta[0] = y; // ta[0] = 10
		ta[0] += 2; // ta[0] = 12
		ta[0] ++; // ta[0] = 13
		tb[0] = b1 || (!b1); // tb[0] = true
	};
	f(); // x = 2;
	write(x);
   }
}